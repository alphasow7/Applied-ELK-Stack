# AgriTech Platform — Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=change-me-to-a-secure-random-string-in-production

# Africa's Talking (USSD/SMS Gateway)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-api-key-here

# Optional: Override database URL
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agritech

# Optional: Logstash
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5044
